// ─── 画像アップスケール（間取り図用）───
function boxBlurSingle(data,w,h,r){
  const out=new Uint8ClampedArray(data.length);
  for(let y=0;y<h;y++){
    let rs=0,gs=0,bs=0,as=0,cnt=0;
    for(let x=-r;x<=r;x++){const xi=Math.min(w-1,Math.max(0,x)),idx=(y*w+xi)*4;rs+=data[idx];gs+=data[idx+1];bs+=data[idx+2];as+=data[idx+3];cnt++;}
    for(let x=0;x<w;x++){
      const idx=(y*w+x)*4;out[idx]=rs/cnt;out[idx+1]=gs/cnt;out[idx+2]=bs/cnt;out[idx+3]=as/cnt;
      const rx=Math.max(0,x-r),ax=Math.min(w-1,x+r+1),ri=(y*w+rx)*4,ai=(y*w+ax)*4;
      rs+=data[ai]-data[ri];gs+=data[ai+1]-data[ri+1];bs+=data[ai+2]-data[ri+2];as+=data[ai+3]-data[ri+3];
    }
  }
  const tmp=new Uint8ClampedArray(out.length);
  for(let x=0;x<w;x++){
    let rs=0,gs=0,bs=0,as=0,cnt=0;
    for(let y=-r;y<=r;y++){const yi=Math.min(h-1,Math.max(0,y)),idx=(yi*w+x)*4;rs+=out[idx];gs+=out[idx+1];bs+=out[idx+2];as+=out[idx+3];cnt++;}
    for(let y=0;y<h;y++){
      const idx=(y*w+x)*4;tmp[idx]=rs/cnt;tmp[idx+1]=gs/cnt;tmp[idx+2]=bs/cnt;tmp[idx+3]=as/cnt;
      const ry=Math.max(0,y-r),ay=Math.min(h-1,y+r+1),ri=(ry*w+x)*4,ai=(ay*w+x)*4;
      rs+=out[ai]-out[ri];gs+=out[ai+1]-out[ri+1];bs+=out[ai+2]-out[ri+2];as+=out[ai+3]-out[ri+3];
    }
  }
  return tmp;
}
function enhanceFloorPlan(src,callback){
  const img=new Image();
  img.onload=function(){
    const TARGET=2400,maxDim=Math.max(img.width,img.height);
    const scale=maxDim>=TARGET?1.0:TARGET/maxDim;
    const nw=Math.round(img.width*scale),nh=Math.round(img.height*scale);
    const cv=document.createElement('canvas');cv.width=nw;cv.height=nh;
    const ctx=cv.getContext('2d');
    ctx.imageSmoothingEnabled=true;ctx.imageSmoothingQuality='high';
    ctx.drawImage(img,0,0,nw,nh);
    // Unsharp mask
    const d=ctx.getImageData(0,0,nw,nh);
    let buf=new Uint8ClampedArray(d.data);
    for(let p=0;p<3;p++)buf=boxBlurSingle(buf,nw,nh,2);
    const out=new Uint8ClampedArray(d.data);
    for(let i=0;i<out.length;i+=4){
      for(let c=0;c<3;c++){const diff=d.data[i+c]-buf[i+c];out[i+c]=Math.min(255,Math.max(0,Math.round(d.data[i+c]+1.5*diff)));}
      out[i+3]=d.data[i+3];
    }
    // Contrast
    for(let i=0;i<out.length;i+=4){for(let c=0;c<3;c++){out[i+c]=Math.min(255,Math.max(0,Math.round((out[i+c]-128)*1.15+128)));}}
    ctx.putImageData(new ImageData(out,nw,nh),0,0);
    if(scale>1.05) console.log('[RENOBEST] 図面を'+scale.toFixed(2)+'x高解像度化: '+img.width+'x'+img.height+' → '+nw+'x'+nh+'px');
    callback(cv.toDataURL('image/png',1.0));
  };
  img.src=src;
}


