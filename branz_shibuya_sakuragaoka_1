/* ─── スマートフォン向け：インラインgridをレスポンシブ対応 ─── */
(function(){
  function applyMobile(){
    var isMobile = window.innerWidth <= 768;
    // P2・P3のインラインgridを縦積みに
    document.querySelectorAll('.page [style*="grid-template-columns"]').forEach(function(el){
      if(isMobile){
        el.dataset._origStyle = el.dataset._origStyle || el.getAttribute('style');
        var s = el.getAttribute('style') || '';
        if(!s.includes('sm-stacked')){
          el.style.gridTemplateColumns = '1fr';
          el.style.height = 'auto';
          el.dataset.smStacked = '1';
        }
      } else {
        if(el.dataset._origStyle){
          el.setAttribute('style', el.dataset._origStyle);
          delete el.dataset.smStacked;
        }
      }
    });
  }
  applyMobile();
  window.addEventListener('resize', applyMobile);
})();
</script>

