function saveForCustomer(){
  let h='<!DOCTYPE html>\n'+document.documentElement.outerHTML;

  // ① ツールバーを顧客用に置換（マーカーを使って確実に）
  const tbStart=h.indexOf('<div class="toolbar">');
  const tbEnd=h.indexOf('<!-- END_TOOLBAR -->');
  if(tbStart>=0&&tbEnd>tbStart){
    const activeLang=document.querySelector('.lang-btn.active')?.textContent||'日本語';
    const dmLabel=TB[activeLang]?.dm||'📄 DMマイソク';
    const printLabel=TB[activeLang]?.print||'🖨 PDF印刷';
    const customerToolbar=`<div class="toolbar">
  <div class="tb-left">
    <div class="lang-btns">
      <button class="lang-btn${activeLang==='日本語'?' active':''}" onclick="setLang('ja')">日本語</button>
      <button class="lang-btn${activeLang==='English'?' active':''}" onclick="setLang('en')">English</button>
      <button class="lang-btn${activeLang==='中文简体'?' active':''}" onclick="setLang('zh-cn')">中文简体</button>
      <button class="lang-btn${activeLang==='中文繁體'?' active':''}" onclick="setLang('zh-tw')">中文繁體</button>
    </div>
  </div>
  <div class="tb-right">
    <button class="btn-dm" onclick="generateDM()" data-tb="dm">${dmLabel}</button>
    <button class="btn-print" onclick="window.print()" data-tb="print">${printLabel}</button>
  </div>
</div>
<!-- END_TOOLBAR -->`;
    h=h.substring(0,tbStart)+customerToolbar+h.substring(tbEnd+'<!-- END_TOOLBAR -->'.length);
  }

  // ②属性を全削除
  h=h.replace(/(?:="[^"]*")?/gi,'');

  // ③ 画像差替クリックハンドラを削除
  h=h.replace(/ onclick="document\.getElementById\('fi-[^']*'\)\.click\(\)"/g,'');

  // ④ ファイルinputを全削除
  h=h.replace(/<input[^>]*type="file"[^>]*>\n?/gi,'');

  // ⑤ img-ovカメラオーバーレイを削除
  h=h.replace(/<div class="img-ov"><div class="img-ov-ic"[^>]*>[^<]*<\/div><div class="img-ov-tx">[^<]*<\/div><\/div>/g,'');
  h=h.replace(/<div class="img-ov"><div class="img-ov-ic"[^>]*>[^<]*<\/div><\/div>/g,'');

  // ⑥ 編集無効CSSを追加（画像サイズを絶対に上書きしない）
  h=h.replace('</style>',`
/* 顧客用閲覧モード */
.img-wrap{cursor:default!important;}
.img-wrap:hover img{filter:none!important;}
.area-photo-wrap{cursor:default!important;}
.area-photo-wrap:hover img{filter:none!important;}
.p1-qr-wrap{cursor:default!important;}
</style>`);

  // ⑦ ファイル名＆保存
  const propName=(document.querySelector('[data-key="prop_name"]')?.textContent?.trim()||'提案資料').replace(/\s+/g,'_');
  const blob=new Blob([h],{type:'text/html;charset=utf-8'});
  const a=document.createElement('a');
  a.href=URL.createObjectURL(blob);
  a.download=propName+'_顧客用.html';
  a.click();
}

