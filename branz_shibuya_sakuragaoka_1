<!DOCTYPE html>
<html lang="ja"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ブランズ渋谷桜丘 — 提案資料</title>
<link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700;900&amp;family=Shippori+Mincho:wght@400;700&amp;family=DM+Mono:wght@400;500&amp;display=swap" rel="stylesheet">
<style>
*,*::before,*::after{box-sizing:border-box;margin:0;padding:0;}
:root{--N:#1D2A44;--G:#C19F6E;--CR:#F8F5EF;}
body{font-family:'Noto Sans JP',sans-serif;background:#d8d3c8;display:flex;flex-direction:column;align-items:center;gap:24px;padding:72px 20px 40px;}

.toolbar{position:fixed;top:0;left:0;right:0;z-index:9999;background:var(--N);padding:0 22px;height:52px;display:flex;align-items:center;justify-content:space-between;box-shadow:0 2px 14px rgba(0,0,0,.3);font-family:'Noto Sans JP',sans-serif;}
.tb-left{display:flex;align-items:center;gap:10px;}
.tb-hint{color:rgba(255,255,255,.65);font-size:12px;}
.tb-hint strong{color:#C19F6E;}
.lang-btns{display:flex;gap:4px;background:rgba(255,255,255,.08);border-radius:8px;padding:4px;}
.lang-btn{padding:5px 12px;border:none;border-radius:6px;font-size:11px;font-weight:700;cursor:pointer;font-family:'Noto Sans JP',sans-serif;background:transparent;color:rgba(255,255,255,.6);transition:all .15s;}
.lang-btn.active{background:#C19F6E;color:var(--N);}
.lang-btn:hover:not(.active){background:rgba(255,255,255,.15);color:#fff;}
.tb-right{display:flex;gap:8px;}
.tb-right button{padding:7px 18px;border:none;border-radius:6px;font-size:12px;font-weight:700;cursor:pointer;font-family:'Noto Sans JP',sans-serif;}
.btn-save{background:#C19F6E;color:var(--N);}
.btn-print{background:#fff;color:var(--N);}
.btn-customer{background:#1a7a4a;color:#fff;}
.btn-customer:hover{background:#23a060;}


.page{width:277mm;min-height:190mm;position:relative;overflow:hidden;background:#fff;box-shadow:0 4px 32px rgba(0,0,0,.18);padding:8mm 9mm 13mm;}
[contenteditable]{outline:none;cursor:text;}
[contenteditable]:hover{background:rgba(193,159,110,.1);border-radius:2px;}
[contenteditable]:focus{background:rgba(193,159,110,.18);border-radius:2px;box-shadow:0 0 0 2px rgba(193,159,110,.4);}

.img-wrap{position:relative;cursor:pointer;overflow:hidden;border-radius:6px;}
.img-wrap img{width:100%;height:100%;object-fit:cover;display:block;transition:filter .2s;}
.img-wrap:hover img{filter:brightness(.72);}
.img-ov{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:5px;opacity:0;transition:opacity .2s;pointer-events:none;}
.img-wrap:hover .img-ov{opacity:1;}
.img-ov-ic{width:38px;height:38px;background:rgba(255,255,255,.9);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:17px;}
.img-ov-tx{color:#fff;font-size:10px;font-weight:700;background:rgba(0,0,0,.5);padding:2px 8px;border-radius:4px;}
.img-input{display:none;}

.area-photo-wrap{position:relative;cursor:pointer;overflow:hidden;border-radius:5px;height:22mm;}
.area-photo-wrap img{width:100%;height:100%;object-fit:cover;display:block;transition:filter .2s;}
.area-photo-wrap:hover img{filter:brightness(.7);}
.area-photo-wrap:hover .img-ov{opacity:1;}
.area-caption{position:absolute;bottom:0;left:0;right:0;background:rgba(29,42,68,.72);padding:2px 4px;font-size:5.5pt;color:rgba(255,255,255,.95);text-align:center;font-weight:700;}

.ph{display:flex;align-items:center;justify-content:space-between;padding-bottom:5px;border-bottom:1.5px solid #C19F6E;margin-bottom:7px;}
.ph-lbl{font-size:6.5pt;color:#C19F6E;font-weight:900;letter-spacing:.16em;text-transform:uppercase;margin-bottom:1px;}
.ph-name{font-size:11pt;color:#1D2A44;font-weight:900;font-family:'Shippori Mincho',serif;}
.ph-r{text-align:right;}
.ph-agent{font-size:7.5pt;color:#1D2A44;font-weight:700;}
.ph-pg{font-size:7pt;color:#aaa;}
.pf{position:absolute;bottom:0;left:0;right:0;padding:4px 9mm;background:#F8F5EF;border-top:1px solid #ddd;display:flex;justify-content:space-between;align-items:center;}
.pf-addr{font-size:6.5pt;color:#888;}
.pf-brand{font-size:8.5pt;font-weight:900;letter-spacing:.16em;color:#C19F6E;}
.pf-pg{font-size:7pt;color:#C19F6E;font-weight:700;}
.sec-ttl{font-size:6pt;color:#C19F6E;font-weight:900;letter-spacing:.1em;text-transform:uppercase;border-bottom:1.5px solid #C19F6E;padding-bottom:2px;margin-bottom:3px;}
.ck{color:#C19F6E;font-weight:900;flex-shrink:0;}
.fac-grid{display:grid;grid-template-columns:1fr 1fr;gap:1px 5px;}
.fac-item{display:flex;gap:4px;font-size:6.5pt;color:#1D2A44;align-items:baseline;padding:1px 0;}

/* ═══ P1 ═══ */
.p1-layout{display:grid;grid-template-columns:minmax(0,38%) minmax(0,62%);gap:9px;height:163mm;}
.p1-photo{position:relative;height:100%;border-radius:7px;overflow:hidden;}
.p1-photo img{width:100%;height:100%;object-fit:cover;display:block;}
.p1-price-bar{position:absolute;bottom:0;left:0;right:0;background:linear-gradient(to top,rgba(29,42,68,.96) 0%,rgba(29,42,68,.82) 55%,transparent 100%);padding:18px 12px 10px;}
.p1-price-label{font-size:6pt;color:#C19F6E;font-weight:900;letter-spacing:.12em;margin-bottom:2px;}
.p1-price-val{font-size:20pt;color:#C19F6E;font-weight:900;font-family:'DM Mono',monospace;line-height:1;}
.p1-price-note{font-size:6.5pt;color:rgba(255,255,255,.55);margin-top:1px;}
.p1-price-fx{font-size:6.5pt;color:rgba(255,255,255,.7);margin-top:2px;}
.p1-right{display:flex;flex-direction:column;gap:5px;overflow:hidden;}

/* Catch copy — story-driven */
.p1-catch{font-size:11pt;color:#1D2A44;font-weight:900;font-family:'Shippori Mincho',serif;line-height:1.35;}
.p1-sub{font-size:7pt;color:#555;line-height:1.5;margin-top:2px;}

/* Badges — story-driven */
.badges{display:flex;gap:3px;}
.badge{background:#F8F5EF;border:1px solid #ede9df;border-radius:5px;padding:5px 5px;flex:1;text-align:center;overflow:hidden;}
.badge-icon{font-size:11pt;margin-bottom:2px;}
.badge-main{font-size:6.5pt;color:#1D2A44;font-weight:700;line-height:1.3;}
.badge-sub{font-size:5.5pt;color:#888;margin-top:1px;line-height:1.3;}

.stats-lbl{font-size:5.5pt;color:#C19F6E;font-weight:900;letter-spacing:.08em;text-transform:uppercase;margin-bottom:2px;}
.stats{display:flex;gap:3px;}
.stat{background:#fff;border:1px solid #ede9df;border-radius:5px;padding:4px 5px;flex:1;text-align:center;}
.stat-v{font-size:15pt;color:#1D2A44;font-weight:900;font-family:'DM Mono',monospace;line-height:1;}
.stat-u{font-size:7.5pt;color:#C19F6E;margin-left:1px;}
.stat-l{font-size:5.5pt;color:#aaa;margin-top:1px;}
.stat-e{font-size:5pt;color:#C19F6E;font-weight:700;}
.ov-row{display:grid;grid-template-columns:58px 1fr;gap:0 5px;padding:2px 0 2px 6px;border-bottom:1px solid #f0ece3;align-items:baseline;}
.ov-l{font-size:6.5pt;color:#888;font-weight:600;}
.ov-v{font-size:6.5pt;color:#1D2A44;font-weight:500;line-height:1.35;}
.p1-fac-row{display:grid;grid-template-columns:1fr 1fr;gap:6px;}

/* ═══ P2 ═══ */
.p2-grid{display:grid;grid-template-columns:minmax(0,44%) minmax(0,56%);gap:10px;height:118mm;margin-bottom:4px;}
.ls-col{display:flex;flex-direction:column;gap:4px;}
.ls-img-wrap{border-radius:6px;overflow:hidden;height:40mm;flex-shrink:0;}
.ls-img-wrap img{width:100%;height:100%;object-fit:cover;display:block;}

/* Shibuya Sakura Stage context box */
.stage-box{background:#1D2A44;border-radius:6px;padding:7px 10px;flex-shrink:0;}
.stage-kicker{font-size:5.5pt;color:#C19F6E;font-weight:900;letter-spacing:.12em;text-transform:uppercase;margin-bottom:3px;}
.stage-title{font-size:8pt;color:#fff;font-weight:700;font-family:'Shippori Mincho',serif;margin-bottom:4px;line-height:1.3;}
.stage-body{font-size:6.5pt;color:rgba(255,255,255,.75);line-height:1.55;}

/* Access infographic */
.access-row{display:grid;grid-template-columns:repeat(4,1fr);gap:3px;}
.ac-badge{background:#F8F5EF;border:1px solid #ede9df;border-radius:5px;padding:4px 3px;text-align:center;}
.ac-badge-icon{font-size:10pt;margin-bottom:1px;}
.ac-badge-dest{font-size:6pt;color:#1D2A44;font-weight:700;line-height:1.2;}
.ac-badge-time{font-size:7.5pt;color:#C19F6E;font-weight:900;font-family:'DM Mono',monospace;margin-top:1px;}
.ac-badge-note{font-size:5.5pt;color:#aaa;}

.area-lbl{font-size:6pt;color:#C19F6E;font-weight:900;letter-spacing:.08em;text-transform:uppercase;margin-bottom:2px;}
.area-photos{display:grid;grid-template-columns:repeat(3,1fr);gap:4px;}

/* Recommend cards — story-driven */
.rec-header{font-size:8pt;color:#1D2A44;font-weight:700;font-family:'Shippori Mincho',serif;margin-bottom:4px;}
.rec-cards{display:flex;flex-direction:column;gap:5px;}
.rec-card{display:flex;gap:7px;align-items:flex-start;padding:7px 9px;background:#fff;border:1px solid #ede9df;border-left:3px solid #C19F6E;border-radius:0 5px 5px 0;}
.rec-num{font-size:12pt;color:#C19F6E;font-weight:900;font-family:'DM Mono',monospace;line-height:1;flex-shrink:0;min-width:20px;}
.rec-hd{font-size:8pt;color:#1D2A44;font-weight:700;line-height:1.35;margin-bottom:2px;text-align:left;}
.rec-desc{font-size:7pt;color:#555;line-height:1.55;text-align:left;}

.summary{background:#1D2A44;border-radius:7px;padding:9px 18px;display:flex;align-items:center;justify-content:space-between;}
.sum-lbl{font-size:6.5pt;color:#C19F6E;font-weight:900;letter-spacing:.1em;margin-bottom:3px;}
.sum-copy{font-size:12pt;color:#fff;font-weight:700;font-family:'Shippori Mincho',serif;line-height:1.4;}
.sum-r{text-align:right;border-left:1px solid rgba(255,255,255,.15);padding-left:16px;flex-shrink:0;}
.sum-sub{font-size:7pt;color:rgba(255,255,255,.5);}
.sum-v{font-size:7.5pt;color:#fff;}
.sum-ag{font-size:7.5pt;color:#C19F6E;margin-top:3px;font-weight:700;}

/* ═══ P3 ═══ */
.p3-grid{display:grid;grid-template-columns:minmax(0,58%) minmax(0,42%);gap:9px;height:132mm;}
.fp-wrap{background:#F8F5EF;border-radius:7px;border:1px solid #ede9df;overflow:hidden;display:flex;align-items:center;justify-content:center;padding:6px;}
.fp-wrap img{max-width:100%;max-height:100%;object-fit:contain;border-radius:4px;}
.rooms-wrap{background:#F8F5EF;border-radius:6px;padding:7px 9px;border:1px solid #ede9df;}
.room-row{display:grid;grid-template-columns:1fr auto;gap:0 7px;padding:3px 0;border-bottom:1px dotted #ddd;align-items:baseline;}
.room-n{font-size:8pt;color:#1D2A44;font-weight:700;}
.room-note{font-size:7pt;color:#888;margin-left:5px;}
.room-s{font-size:9.5pt;color:#C19F6E;font-weight:900;font-family:'DM Mono',monospace;white-space:nowrap;}
.eq-grid{display:grid;grid-template-columns:1fr 1fr;gap:2px 7px;}
.eq-item{display:flex;gap:4px;font-size:7.5pt;color:#1D2A44;padding:1px 0;align-items:baseline;}
.plan-hl{background:#1D2A44;border-radius:6px;padding:9px 11px;}
.plan-hl-l{font-size:6.5pt;color:#C19F6E;font-weight:900;letter-spacing:.1em;margin-bottom:4px;}
.plan-hl-t{font-size:8.5pt;color:#fff;line-height:1.6;font-weight:500;}


/* QR Contact Section */
.p1-contact{display:flex;align-items:center;gap:10px;border-top:1.5px solid #e8e3d8;padding:6px 4px 4px;margin-top:auto;}
.p1-qr-item{display:flex;flex-direction:column;align-items:center;gap:3px;flex-shrink:0;}
.p1-qr-wrap{width:18mm;height:18mm;max-width:18mm;max-height:18mm;min-width:18mm;min-height:18mm;background:#f8f8f8;border-radius:4px;overflow:hidden!important;cursor:pointer;position:relative;flex-shrink:0;border:1px solid #ddd;}}
.p1-qr-wrap img{width:100%!important;height:100%!important;max-width:18mm!important;max-height:18mm!important;object-fit:contain!important;display:block!important;}}
.p1-qr-wrap:hover img{{filter:brightness(.8);}}
.p1-qr-label{font-size:6pt;color:#1D2A44;font-weight:700;letter-spacing:.06em;}}
.p1-brand-sec{display:none;}}
.p1-brand-logo{display:none;}}
.p1-brand-agent{display:none;}}


/* P1連絡先テキスト色（紺色） */
.p1-company{font-size:6.5pt;color:#1D2A44;font-weight:900;margin-bottom:2px;font-family:'Shippori Mincho',serif;letter-spacing:.06em;}
.p1-addr{font-size:5.5pt;color:#444;line-height:1.6;margin-bottom:2px;}
.p1-contact-row{font-size:5.5pt;color:#444;line-height:1.7;}
.p1-contact-row span{color:#1D2A44;font-weight:700;margin-right:3px;}
.p1-brand-sec{display:none!important;}
.p1-brand-logo,.p1-brand-agent{display:none!important;}


/* P1 キャッチコピー */
.p1-catchphrase{flex:1;border-left:1.5px solid #e8e3d8;padding-left:10px;font-size:5.5pt;color:#1D2A44;line-height:1.75;font-style:normal;font-family:'Noto Sans JP',sans-serif;}
.p1-catchphrase em{font-size:6pt;color:#1D2A44;font-weight:700;font-style:normal;display:block;margin-bottom:2px;}


.ph-agent-label{font-size:5.5pt;color:#aaa;letter-spacing:.08em;margin-bottom:1px;}

@media print{
  body{background:#fff;padding:0;gap:0;}
  .toolbar{display:none!important;}
  .page{box-shadow:none;page-break-after:always;}
  .page:last-child{page-break-after:auto;}
  @page{size:A4 landscape;margin:0;}
  *{-webkit-print-color-adjust:exact!important;print-color-adjust:exact!important;}
}

/* 画像削除ボタン */
.img-ov{pointer-events:all;}
.img-ov-del{width:30px;height:30px;background:rgba(220,60,60,.85);border:none;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;cursor:pointer;color:#fff;flex-shrink:0;transition:background .15s;}
.img-ov-del:hover{background:rgba(200,30,30,1);}
.img-ov-row{display:flex;gap:6px;align-items:center;}

/* ═══ スマートフォン表示最適化 ═══ */
@media screen and (max-width:768px){
  body{padding:60px 0 20px;gap:12px;background:#d8d3c8;}

  /* ツールバー：スマホ向けに2段構成 */
  .toolbar{height:auto;padding:6px 10px;flex-direction:column;gap:6px;align-items:flex-start;}
  .tb-left{flex-wrap:wrap;gap:6px;width:100%;}
  .tb-hint{font-size:10px;display:none;} /* 編集ヒントはスマホでは非表示 */
  .lang-btns{flex-wrap:wrap;}
  .lang-btn{padding:4px 8px;font-size:10px;}
  .tb-right{width:100%;gap:4px;flex-wrap:wrap;}
  .tb-right button{padding:5px 10px;font-size:10px;flex:1;min-width:0;}
  body{padding-top:88px;} /* ツールバー2段分の余白 */

  /* ページ：幅100%・スクロール対応 */
  .page{width:100%;min-height:auto;padding:4mm 4mm 8mm;overflow:visible;box-shadow:0 2px 12px rgba(0,0,0,.15);}

  /* P1レイアウト：縦積みに変更 */
  .p1-layout{grid-template-columns:1fr!important;height:auto!important;gap:8px;}
  .p1-photo{height:55vw!important;border-radius:5px;}
  .p1-right{gap:6px;}
  .p1-catch{font-size:9pt!important;}
  .p1-sub{font-size:6pt!important;}

  /* バッジ */
  .badges{gap:4px;}
  .badge{padding:4px 3px;}
  .badge-icon{font-size:9pt!important;}
  .badge-main{font-size:5.5pt!important;}
  .badge-sub{font-size:4.5pt!important;}

  /* STATS */
  .stats{gap:3px;}
  .stat-v{font-size:11pt!important;}
  .stat-l{font-size:4.5pt!important;}
  .stat-e{font-size:4pt!important;}

  /* 物件概要 */
  .ov-row{grid-template-columns:48px 1fr;}
  .ov-l{font-size:5.5pt!important;}
  .ov-v{font-size:5.5pt!important;}

  /* 施設チェックリスト */
  .fac-grid{grid-template-columns:1fr 1fr;gap:1px 4px;}
  .fac-item{font-size:5.5pt!important;}
  .p1-fac-row{grid-template-columns:1fr 1fr;gap:4px;}

  /* QR・連絡先 */
  .p1-contact{gap:6px;padding:4px 2px 2px;}
  .p1-qr-wrap{width:14mm!important;height:14mm!important;max-width:14mm!important;max-height:14mm!important;min-width:14mm!important;min-height:14mm!important;}
  .p1-qr-label{font-size:5pt!important;}
  .p1-company{font-size:5.5pt!important;}
  .p1-addr{font-size:4.5pt!important;}
  .p1-contact-row{font-size:4.5pt!important;}
  .p1-catchphrase{font-size:4.5pt!important;padding-left:6px;}

  /* P2：縦積みに変更 */
  .p2-grid{grid-template-columns:1fr!important;height:auto!important;gap:8px;}
  .ls-col{gap:6px;}
  .ls-img-wrap{height:50vw!important;}

  /* アクセスバッジ */
  .access-row{grid-template-columns:repeat(2,1fr);gap:4px;}
  .ac-badge-dest{font-size:5pt!important;}
  .ac-badge-time{font-size:6pt!important;}
  .ac-badge-note{font-size:4.5pt!important;}

  /* エリア写真 */
  .area-photos{grid-template-columns:repeat(3,1fr);gap:3px;}
  .area-photo-wrap{height:18mm!important;}
  .area-caption{font-size:4.5pt!important;}

  /* おすすめカード */
  .rec-header{font-size:7pt!important;}
  .rec-cards{gap:4px;}
  .rec-card{padding:5px 7px;gap:5px;}
  .rec-num{font-size:10pt!important;}
  .rec-hd{font-size:6.5pt!important;}
  .rec-desc{font-size:5.5pt!important;}

  /* サマリーバー */
  .summary{flex-direction:column;gap:6px;padding:7px 12px;align-items:flex-start;}
  .sum-copy{font-size:9pt!important;}
  .sum-r{border-left:none;border-top:1px solid rgba(255,255,255,.15);padding-left:0;padding-top:6px;width:100%;}

  /* P3：縦積みに変更 */
  .p3-grid{grid-template-columns:1fr!important;height:auto!important;gap:8px;}
  .fp-wrap{padding:4px;min-height:55vw;}
  .rooms-wrap{padding:5px 7px;}
  .room-row{grid-template-columns:1fr auto;gap:0 4px;}
  .room-n{font-size:6.5pt!important;}
  .room-s{font-size:8pt!important;}
  .room-note{font-size:5.5pt!important;}
  .eq-grid{grid-template-columns:1fr 1fr;gap:1px 4px;}
  .eq-item{font-size:6pt!important;}
  .plan-hl{padding:6px 8px;}
  .plan-hl-l{font-size:5.5pt!important;}
  .plan-hl-t{font-size:7pt!important;}

  /* DMモーダル内のグリッドもスマホ対応 */
  .dm-layout{flex-direction:column!important;}

  /* ページヘッダー・フッター */
  .ph{padding-bottom:4px;margin-bottom:5px;}
  .ph-lbl{font-size:5.5pt!important;}
  .ph-name{font-size:9pt!important;}
  .ph-agent{font-size:6pt!important;}
  .pf-addr{font-size:5pt!important;}
  .pf-brand{font-size:7pt!important;}
  .pf-pg{font-size:5.5pt!important;}

  /* セクションタイトル */
  .sec-ttl{font-size:5pt!important;}

  /* 価格バー */
  .p1-price-val{font-size:15pt!important;}
  .p1-price-label{font-size:5pt!important;}
  .p1-price-note{font-size:5pt!important;}
  .p1-price-fx{font-size:5pt!important;}

  /* ステージボックス */
  .stage-box{padding:5px 8px;}
  .stage-kicker{font-size:4.5pt!important;}
  .stage-title{font-size:6.5pt!important;}
  .stage-body{font-size:5.5pt!important;}

  /* P2グリッドの右側インライン */
  [style*="grid-template-columns:minmax(0,42%)"],
  [style*="grid-template-columns:minmax(0,44%)"],
  [style*="grid-template-columns:minmax(0,58%)"]{
    grid-template-columns:1fr!important;
    height:auto!important;
  }
}

/* 顧客用閲覧モード */
.img-wrap{cursor:default!important;}
.img-wrap:hover img{filter:none!important;}
.area-photo-wrap{cursor:default!important;}
.area-photo-wrap:hover img{filter:none!important;}
.p1-qr-wrap{cursor:default!important;}
</style>
</head>
<body>

<div class="toolbar">
  <div class="tb-left">
    <div class="lang-btns">
